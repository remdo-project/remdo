{
  // Selection lives here now (was tools/lint-md.sh): `globs` walks the disk for
  // Markdown and `gitignore: true` subtracts every .gitignore (root and nested),
  // so the set = tracked + new-untracked-not-ignored .md — the git-based
  // semantics the shell script had, minus the fail-loud-on-empty guard (cli2
  // reports 0 files instead). Deleted-but-unstaged paths aren't on disk, so the
  // old existence filter is unnecessary here.
  "globs": ["**/*.md"],
  "gitignore": true,
  // globby's `gitignore` honours .gitignore files but not `.git/` itself, and it
  // follows symlinked directories — neither of which the old `git ls-files`
  // selection did, and cli2 does NOT dedup the results by resolved path, so each
  // symlinked mirror re-lints its target. So
  // exclude, to match git's no-symlink-traversal, the skill-mirror symlink dirs
  // (each re-exposes a SKILL.md already linted at its real path) and `.git/`
  // (repo internals, e.g. ref-log files ending in `.md`). node_modules is
  // excluded too (vendored `.md`, never ours). Note `gitignore: true` also drops
  // tracked-but-gitignored files — a deliberate difference from `git ls-files`,
  // acceptable because such files are not authored docs.
  "ignores": [
    ".git",
    "node_modules",
    // Symlink mirrors only — one entry per `.claude/skills/*` that is a symlink
    // to `.agents/skills/*`. List EXACTLY the symlinks: real adapter dirs
    // (remdo-simplify, playground) hold their own SKILL.md and must stay linted.
    // Kept in sync by tests/unit/skills/embedded.spec.ts (fails if a symlink is
    // missing here).
    ".claude/skills/remdo-change-flow",
    ".claude/skills/remdo-deps-refresh",
    ".claude/skills/remdo-docs-align",
    ".claude/skills/remdo-feature-flow",
    ".claude/skills/remdo-refine",
    ".claude/skills/remdo-sync",
    // Versioned adapters generated by OpenSpec and refreshed with
    // `./tools/openspec update`; validate them through OpenSpec rather than
    // imposing this repository's authored-Markdown style on upstream output.
    ".claude/commands/opsx",
    ".claude/skills/openspec-*/**",
    ".codex/skills/openspec-*/**"
  ],
  // Link/anchor validation rides markdownlint's own parser:
  // relative-link existence + `#fragment` heading match (MD051-style),
  // external and absolute paths ignored. The RemDo doc-invariant rules
  // (temporal-status, references-shape) are NOT part of this product gate —
  // they are the remdo-docs-align skill's private tools
  // (.agents/skills/remdo-docs-align/tools/check-doc-rules.sh).
  "customRules": [
    "markdownlint-rule-relative-links"
  ],
  "config": {
    "default": true,
    "relative-links": { "root_path": "." }, // root-relative `/docs/...` links validate against the repo root
    "MD013": {
      "line_length": 80,
      "code_blocks": false,
      "tables": false
    },
    // MD012: existing docs intentionally keep double-blank separators.
    "MD012": false,
    // MD029 "ordered": sequential list numbering; a mechanical renumbering
    // slip (e.g. a duplicated item number) is a real observed defect class.
    "MD029": { "style": "ordered" },
    // MD033: allow inline HTML fragments already present.
    "MD033": false,
    // MD040: allow unlabeled code fences in legacy sections.
    "MD040": false,
    // MD041: skip first-heading requirement for shared snippets.
    "MD041": false,
    // MD060: keep current table alignment as-is.
    "MD060": false
  }
}
