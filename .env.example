# shellcheck disable=SC2034
# RemDo environment overrides (minimal).
# Defaults live in tools/env.defaults.sh; set only what you need to override.

# Server operator secret for admin provisioning actions. Required in production.
# Generate at least 32 random characters, for example: openssl rand -base64 32
ADMIN_SECRET=
# Canonical public app URL for managed/server mode. Required in production, for
# example: APP_PUBLIC_URL=https://www.remdo.com
# Local dev derives the auth URL from http://${HOST}:${PORT}.
# APP_PUBLIC_URL=

# Optional secret overrides. Leave unset: AUTH_SECRET and the Y-Sweet
# auth_key/server_token pair are auto-bootstrapped into DATA_DIR on first run
# (env -> DATA_DIR file -> generate+persist). Set them only to pin/override an
# externally managed value. Generate a matched Y-Sweet pair with
# `pnpm exec y-sweet gen-auth --json`.
# AUTH_SECRET=
# YSWEET_AUTH_KEY=
# YSWEET_SERVER_TOKEN=

# Optional; dev/test defaults to true, production defaults to false.
# ALLOW_SIGNUP=false
# Dev port knob: PORT and all secondary dev service ports derive from PORT_BASE.
PORT_BASE=4000
# In production the listen PORT is independent (platform-injected, else 8080);
# it is never derived from PORT_BASE or APP_PUBLIC_URL.
# PORT=8080
# Remote scripts.
# Default remote source for tools/remote/*.sh.
# For Render, copy the SSH command from Dashboard -> Connect -> SSH and use /app.
# make-backup.sh appends /data, so /app maps to /app/data/{backup,collab}.
# Prefer service-level SSH targets (no instance slug); slugs can rotate.
# PROD_APP_ADDR=srv-abc123@ssh.frankfurt.render.com:/app
#PROD_APP_ADDR=
# Optional extra backup targets for tools/remote/make-backup.sh.
# Define one var per target; script auto-discovers PROD_APP_ADDR_<suffix>.
# Only alphanumeric suffixes are used (for example: eu, us2).
# PROD_APP_ADDR_vm=deploy@vm.example.com:~/projects/remdo
# PROD_APP_ADDR_render2=srv-def456@ssh.oregon.render.com:/app
