{
	admin off
}

{$CADDY_SITE_ADDRESSES} {
	{$CADDY_TLS_DIRECTIVE}

	route {
		handle /health {
			rewrite * /api/health
			reverse_proxy 127.0.0.1:{env.API_SERVER_PORT}
		}

		# HTTPS clients on the default port may omit :443 from Host.
		@canonical_host {
			host {$CADDY_CANONICAL_HOST}
		}
		handle @canonical_host {
			@app_favicon path /favicon.ico /favicon.svg
			handle @app_favicon {
				root * /srv/remdo
				rewrite * /favicon.svg
				file_server
			}

			@options method OPTIONS
			handle @options {
				respond 204
			}

			@api path /api /api/*
			handle @api {
				reverse_proxy 127.0.0.1:{env.API_SERVER_PORT}
			}

			@well_known path /.well-known /.well-known/*
			handle @well_known {
				reverse_proxy 127.0.0.1:{env.API_SERVER_PORT}
			}

			@collab path /d /d/*
			handle @collab {
				reverse_proxy 127.0.0.1:{env.COLLAB_SERVER_PORT}
			}

			@app_routes not path /api /api/* /.well-known /.well-known/* /d /d/* /doc*
			handle @app_routes {
				route {
					root * /srv/remdo
					try_files {path} {path}/ /index.html
					file_server
				}
			}

			respond 404
		}

		handle {
			redir {$APP_PUBLIC_URL}{uri}
		}
	}
}
