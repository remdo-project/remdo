{
	admin off
}

{$CADDY_SITE_ADDRESSES} {
	{$CADDY_TLS_DIRECTIVE}

	route {
		handle_path /health {
			respond 200
		}

		# HTTPS clients on the default port may omit :443 from Host.
		@canonical_host {
			header Host {$CADDY_CANONICAL_HOST}
			header Host {$CADDY_CANONICAL_HOSTPORT}
		}
		handle @canonical_host {
			@app_favicon path /favicon.ico /favicon.svg
			handle @app_favicon {
				root * /srv/remdo
				rewrite * /favicon.svg
				file_server
			}

			@options method OPTIONS
			handle @options {
				respond 204
			}

			handle /api/* {
				reverse_proxy 127.0.0.1:{env.API_SERVER_PORT}
			}

			handle /d/* {
				reverse_proxy 127.0.0.1:{env.COLLAB_SERVER_PORT}
			}

			@app_routes not path /api/* /d/* /doc*
			handle @app_routes {
				route {
					root * /srv/remdo
					try_files {path} {path}/ /index.html
					file_server
				}
			}

			respond 404
		}

		handle {
			redir https://{$CADDY_CANONICAL_HOSTPORT}{uri}
		}
	}
}
