{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "vite": true,
  "vitest": true,
  "playwright": true,
  "ignoreDependencies": [
    // Invoked as a CLI binary from package scripts and tooling (`pnpm exec playwright ...`).
    "playwright",
    // Wired via the `customRules` array in .markdownlint-cli2.jsonc, which knip does not parse.
    "markdownlint-rule-relative-links"
  ],
  "ignoreUnresolved": [
    // Shell scripts invoked at runtime via spawnSync/execFileSync from specs, not module imports.
    "./tools/env.sh",
    "./tools/prod/docker.sh"
  ],
  // Skill bodies live once under `.agents/skills`; the `.claude` skill dirs are
  // symlink mirrors of them. knip follows those symlinks and would
  // re-discover the same specs under a mirror path, where their
  // `../../_shared/test-support/...` imports resolve against `.claude/skills`
  // (which has no `_shared`) and report as unresolved. Ignore the
  // mirrors so only the canonical `.agents` copy is scanned — the same
  // no-symlink-traversal `.markdownlint-cli2.jsonc` enforces for the doc gate.
  "ignore": [
    ".claude/skills/**"
  ],
  "entry": [
    "playwright.docker.config.ts",
    "tests/e2e/setup/*.setup.ts",
    "tools/**/*.ts",
    "tests/perf/**/*.bench.ts",
    "tests/perf/generate-workload.ts",
    "vitest.bench.perf.config.mts"
  ],
  "project": [
    "{src,tests,tools,config}/**/*.{ts,tsx,mts}",
    ".agents/skills/**/*.{ts,tsx,mts}",
    "*.{ts,mts}"
  ]
}
