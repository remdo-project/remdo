{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "vite": true,
  "vitest": true,
  "playwright": true,
  "ignoreDependencies": [
    // Invoked as a CLI binary from package scripts and tooling (`pnpm exec playwright ...`).
    "playwright",
    // Wired via the `customRules` array in .markdownlint-cli2.jsonc, which knip does not parse.
    "markdownlint-rule-relative-links"
  ],
  "ignoreUnresolved": [
    // Shell scripts invoked at runtime via spawnSync/execFileSync from specs, not module imports.
    "./tools/env.sh",
    "./tools/prod/docker.sh"
  ],
  // Skill bodies live once under `.agents/skills`; the `.claude` skill dirs are
  // symlink mirrors of them. knip follows those symlinks and would
  // re-discover the same specs under a mirror path, where their
  // `../../_shared/test-support/...` imports resolve against `.claude/skills`
  // (which has no `_shared`) and report as unresolved. Ignore the
  // mirrors so only the canonical `.agents` copy is scanned — the same
  // no-symlink-traversal `.markdownlint-cli2.jsonc` enforces for the doc gate.
  "ignore": [
    ".claude/skills/**",
    // Reference-only evidence retained with the retired workflow; never invoke
    // or treat it as part of the active project graph.
    ".agents/skills/obsolete-remdo-change-flow/tools/change-gate.ts"
  ],
  // Test-visible exports that are also used inside their production module are
  // live implementation details, not dead production code.
  "ignoreExportsUsedInFile": true,
  "entry": [
    // Docker bundles these files as production executables; knip does not parse
    // docker/Dockerfile to discover them.
    "tools/remdo-api-server.ts!",
    "tools/snapshot/{cli,backup}.ts!",
    "tools/bootstrap-secrets.ts!",
    "playwright.docker.config.ts",
    "tests/e2e/setup/*.setup.ts",
    "tools/{check-pnpm-policy,collab-server,repo-stats}.ts",
    "tools/{dev,e2e}/**/*.ts",
    "tests/perf/**/*.bench.ts",
    "tests/perf/generate-workload.ts",
    "vitest.bench.perf.config.mts",
    // Standalone skill tools launched from shell; knip cannot discover their
    // TypeScript entry points from those callers.
    ".agents/skills/remdo-verify-change/tools/run-{claude,codex}-review.ts",
    // Opt-in real-provider validation, intentionally outside normal test suites.
    ".agents/skills/remdo-verify-change/tests/committed-range.acceptance.ts"
  ],
  "project": [
    // `!` marks the production graph used by `knip --production`.
    "src/**/*.{ts,tsx,mts}!",
    "!src/**/*.spec.{ts,tsx,mts}!",
    // Shared by dev provisioning and tests, never by a production entry point.
    "!src/server/auth/session-cookie.ts!",
    "config/{index.ts,env/**/*.ts}!",
    "tests/**/*.{ts,tsx,mts}",
    "config/{_internal,eslint,playwright,vite}/**/*.{ts,tsx,mts}",
    "tools/lib/**/*.{ts,tsx,mts}",
    ".agents/skills/**/*.{ts,tsx,mts}",
    "*.{ts,mts}"
  ]
}
