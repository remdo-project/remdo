{
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./data/cache/tsconfig.tsbuildinfo",
    "target": "ES2023",
    "jsx": "react-jsx",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "moduleDetection": "force",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "#client/*": [
        "./src/client/*"
      ],
      "#collaboration/*": [
        "./src/collaboration/*"
      ],
      "#domain/*": [
        "./src/domain/*"
      ],
      "#note-sdk": [
        "./src/note-sdk/index.ts"
      ],
      "#note-sdk/*": [
        "./src/note-sdk/*"
      ],
      "#projection/*": [
        "./src/projection/*"
      ],
      "#platform/*": [
        "./src/platform/*"
      ],
      "#document-routes": [
        "./src/document-routes.ts"
      ],
      "#server/*": [
        "./src/server/*"
      ],
      "#e2e/*": [
        "./tests/e2e/_support/*"
      ],
      "#editor/*": [
        "./tests/e2e/editor/_support/*"
      ],
      "#tests-common/*": [
        "./tests/_support/*"
      ],
      "#config": [
        "./config/index.ts"
      ],
      "#tools/*": [
        "./tools/lib/*"
      ],
      "#tests": [
        "./tests/unit/_support/lib/index.ts"
      ],
      "#fixtures/*": [
        "./tests/fixtures/*"
      ],
      "#tests/*": [
        "./tests/unit/_support/lib/*"
      ],
      "#config/*": [
        "./config/*"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "node",
      "vite/client",
      "vite-plugin-pwa/client"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "./**/*",
    // TS globs skip dot-directories; skill-local tools/tests need an explicit
    // dot-prefixed pattern to be typechecked.
    "./.claude/skills/**/*"
  ],
  "exclude": [
    "**/node_modules/**",
    "./bookmarks/",
    "./dist/",
    "./data/"
  ]
}
